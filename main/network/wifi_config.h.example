#pragma once

// WiFi 配置 - 复制此文件为 wifi_config.h 并填入你的信息
#define WIFI_SSID "your_wifi_ssid"
#define WIFI_PASSWORD "your_wifi_password"
#define WIFI_AUTHMODE WIFI_AUTH_WPA2_PSK

// BSSID 锁定（多路由器环境下指定连接哪台路由器）
// 通过 arp -a 找到网关对应的 MAC 地址填入
#define WIFI_BSSID_LOCK 0
#define WIFI_BSSID "xx:xx:xx:xx:xx:xx"

// 静态IP配置
#define USE_STATIC_IP 1

#if USE_STATIC_IP
#define STATIC_IP_ADDR "192.168.x.x"
#define STATIC_GATEWAY "192.168.x.1"
#define STATIC_NETMASK "255.255.255.0"
#define STATIC_DNS_PRIMARY "8.8.8.8"
#define STATIC_DNS_SECONDARY "8.8.4.4"
#endif
